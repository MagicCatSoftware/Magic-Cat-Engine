  "events": {
    "view:home":      { "name": "view:home",      "payload": "{}" },
    "view:projects":  { "name": "view:projects",  "payload": "{}" },
    "view:contact":   { "name": "view:contact",   "payload": "{}" },
    "projectAdded":   { "name": "projectAdded",   "payload": "{}" },
    "projectsLoaded": { "name": "projectsLoaded", "payload": "{}" },
    "messageSent":    { "name": "messageSent",    "payload": "{}" },
    "messagesLoaded": { "name": "messagesLoaded", "payload": "{}" }
  },

  "pipes": {
    "loadProjects": {
      "name": "loadProjects", "method": "GET", "endpoint": "/api/projects", "collection": "projects",
      "schema": [], "description": "Fetch all portfolio projects from DB", "delay": 200
    },
    "addProject": {
      "name": "addProject", "method": "POST", "endpoint": "/api/projects", "collection": "projects",
      "schema": [
        { "key": "title",       "type": "text" },
        { "key": "category",    "type": "text" },
        { "key": "description", "type": "text" }
      ],
      "description": "Add a new project to the portfolio", "delay": 250
    },
    "sendMessage": {
      "name": "sendMessage", "method": "POST", "endpoint": "/api/messages", "collection": "messages",
      "schema": [
        { "key": "name",    "type": "text" },
        { "key": "email",   "type": "text" },
        { "key": "subject", "type": "text" },
        { "key": "message", "type": "text" }
      ],
      "description": "Submit a contact message", "delay": 250
    },
    "loadMessages": {
      "name": "loadMessages", "method": "GET", "endpoint": "/api/messages", "collection": "messages",
      "schema": [], "description": "Fetch all contact messages from DB", "delay": 200
    }
  },

  "views": {
    "home":     { "name": "home",     "title": "Home",     "description": "Hero section, animated stats, services cards", "params": [] },
    "projects": { "name": "projects", "title": "Projects", "description": "Portfolio grid loaded via loop, add project form",  "params": [] },
    "contact":  { "name": "contact",  "title": "Contact",  "description": "Contact form + message history via loop",          "params": [] }
  },

  "loops": {
    "projectCards": {
      "name": "projectCards",
      "pipeName": "loadProjects",
      "targetId": "M59",
      "description": "Renders project portfolio cards — auto-triggered by loopRender wire on view:projects",
      "template": "<div style=\"background:linear-gradient(135deg,#0f0f1a,#14142a);border:1px solid rgba(124,106,255,0.25);border-radius:16px;padding:28px;box-shadow:0 8px 40px rgba(0,0,0,0.4);box-sizing:border-box\"><div style=\"display:inline-block;background:linear-gradient(135deg,#7c6aff,#ff6b9d);color:#fff;font-size:10px;font-weight:800;padding:4px 14px;border-radius:50px;margin-bottom:16px;letter-spacing:1.5px;text-transform:uppercase\">{{category}}</div><h3 style=\"font-size:17px;font-weight:700;color:#e0e0f0;margin:0 0 10px;line-height:1.3\">{{title}}</h3><p style=\"font-size:13px;color:#7070a8;margin:0;line-height:1.65\">{{description}}</p></div>"
    },
    "messageCards": {
      "name": "messageCards",
      "pipeName": "loadMessages",
      "targetId": "M81",
      "description": "Renders contact message cards on Load Recent Messages click",
      "template": "<div style=\"background:rgba(255,255,255,0.025);border:1px solid rgba(255,255,255,0.07);border-radius:14px;padding:22px;margin-bottom:12px\"><div style=\"display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px\"><strong style=\"color:#7c6aff;font-size:15px\">{{name}}</strong><span style=\"font-size:11px;color:#5050a0;background:rgba(124,106,255,0.1);padding:3px 10px;border-radius:50px\">{{email}}</span></div><div style=\"font-size:11px;color:#9090c0;font-weight:700;letter-spacing:0.5px;margin-bottom:10px;text-transform:uppercase\">{{subject}}</div><p style=\"font-size:14px;color:#b0b0d0;margin:0;line-height:1.6\">{{message}}</p></div>"
    }
  },

