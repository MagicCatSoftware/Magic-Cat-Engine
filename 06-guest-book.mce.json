      "wires": [], "pipeBindings": [], "viewBinding": null,
      "css": { "width": "100%", "background": "#111", "border": "1px solid #fff", "color": "#fff", "padding": "10px 14px", "font-size": "14px", "margin-bottom": "18px", "border-radius": "3px", "display": "block", "resize": "vertical" }
