    },
    "M19": {
      "id": "M19", "tag": "div", "name": "entries_list",
      "attrs": {}, "text": "", "children": [],
      "parentId": "M17",
      "wires": [
        { "eventName": "guestPosted", "action": "loopRender", "actionArgs": "readGuests" }
      ],
      "pipeBindings": [], "viewBinding": null,
      "css": { "background": "#000", "min-height": "60px" }
