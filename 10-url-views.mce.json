  "pipes": {
    "sendMessage": {
      "name": "sendMessage",
      "method": "POST",
      "endpoint": "/api/messages",
      "collection": "messages",
      "delay": 300,
      "schema": [
        { "key": "name",      "type": "text" },
        { "key": "message",   "type": "text" },
        { "key": "timestamp", "type": "text" }
      ],
      "description": "Write a contact message to the DB"
    },
    "loadWork": {
      "name": "loadWork",
      "method": "GET",
      "endpoint": "/api/work",
      "collection": "work",
      "delay": 200,
      "schema": [],
      "description": "Read all portfolio projects"
    }
  },
