  "pipes": {
    "listStaff": {
      "name": "listStaff",
      "method": "GET",
      "endpoint": "/api/staff",
      "collection": "staff",
      "schema": [],
      "description": "Fetch all staff records from the DB",
      "delay": 400
    },
    "addStaff": {
      "name": "addStaff",
      "method": "POST",
      "endpoint": "/api/staff",
      "collection": "staff",
      "schema": [
        { "key": "name",       "type": "text" },
        { "key": "role",       "type": "text" },
        { "key": "department", "type": "text" },
        { "key": "email",      "type": "text" }
      ],
      "description": "Insert a new staff member into the staff collection",
      "delay": 250
    }
  },
  "views": {},
  "loops": {
    "staffCards": {
      "name": "staffCards",
      "pipeName": "listStaff",
      "template": "<div style=\"border:1px solid #2a2a2a;padding:16px 20px;border-radius:4px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center\"><div><div style=\"font-size:15px;font-weight:bold;color:#fff;margin-bottom:3px\">{{name}}</div><div style=\"font-size:13px;color:#aaa;margin-bottom:2px\">{{role}}</div><div style=\"font-size:11px;color:#555;text-transform:uppercase;letter-spacing:1px\">{{department}}</div></div><div style=\"text-align:right\"><div style=\"font-size:12px;color:#666;margin-bottom:6px\">{{email}}</div><div style=\"font-size:10px;color:#333;font-family:monospace\">{{_index}} of {{_total}}</div></div></div>",
      "targetId": "M10",
      "description": "Render each staff record as a card into the staff_list container"
    }
  },
