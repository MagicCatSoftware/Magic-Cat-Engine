      "description": "List of added machines in the left panel"
    },
    "machineCanvas": {
      "name": "machineCanvas",
      "pipeName": "getMachines",
      "targetId": "M32",
      "template": "<{{tag}} style=\"{{css}}\">{{text}}</{{tag}}>",
      "description": "Live canvas: renders each machine as actual HTML"
    }
  },
