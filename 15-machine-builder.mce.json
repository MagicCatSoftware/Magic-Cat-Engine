      "id": "M35", "tag": "button", "name": "export_json_btn",
      "attrs": {
        "onclick": "PipeSystem.fetch('getMachines').then(function(r){var ms={};var ro=[];(r.data||[]).forEach(function(d,i){var id='M'+(i+1);ro.push(id);var co={};String(d.css||'').split(';').forEach(function(p){var k=p.indexOf(':');if(k>-1)co[p.slice(0,k).trim()]=p.slice(k+1).trim();});ms[id]={id:id,tag:d.tag||'div',name:d.name||('el'+(i+1)),attrs:{},text:d.text||'',children:[],parentId:null,wires:[],pipeBindings:[],viewBinding:null,css:co};});var n=ro.length+1;var data={version:'1.0.0',project:{name:'MCE Build'},rootOrder:ro,machines:ms,events:{},pipes:{},views:{},loops:{},logic:{},dbCollections:[],_nextId:n};var json=JSON.stringify(data,null,2);var a=document.createElement('a');try{var b=new Blob([json],{type:'application/json'});a.href=URL.createObjectURL(b);}catch(e){a.href='data:application/json;charset=utf-8,'+encodeURIComponent(json);}a.download='built.mce.json';document.body.appendChild(a);a.click();a.remove();});"
      },
      "text": "Export → MCE JSON",
      "children": [], "parentId": "M33", "wires": [], "pipeBindings": [], "viewBinding": null,
