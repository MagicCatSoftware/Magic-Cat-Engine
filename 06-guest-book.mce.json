  "events": {
    "guestPosted":       { "name": "guestPosted",       "payload": "{}" },
    "guestPosted_reset": { "name": "guestPosted_reset", "payload": "{}" }
  },
  "pipes": {
    "guestPost": {
      "name": "guestPost",
      "direction": "in",
      "collection": "guestbook",
      "schema": [
        { "key": "name",      "type": "text" },
        { "key": "message",   "type": "text" },
        { "key": "location",  "type": "text" },
        { "key": "timestamp", "type": "text" }
      ],
      "description": "Write a guest book entry to the DB"
    },
    "readGuests": {
      "name": "readGuests",
      "direction": "out",
      "collection": "guestbook",
      "schema": [],
      "description": "Read all guest book entries from the DB"
    }
  },
  "views": {},
  "loops": {
    "readGuests": {
      "name": "readGuests",
      "pipeName": "readGuests",
      "targetId": "M19",
      "template": "<div style=\"padding:16px;border-bottom:1px solid #222\"><b style=\"color:#fff\">{{name}}</b> <span style=\"color:#888;font-size:12px\">— {{location}}</span><p style=\"color:#ccc;margin:8px 0 4px;font-size:14px\">{{message}}</p><span style=\"color:#555;font-size:11px\">{{timestamp}}</span></div>",
      "description": "Render guest book entries"
    }
  },
  "logic": {
    "M1":  { "blocks": [] }, "M2":  { "blocks": [] }, "M3":  { "blocks": [] },
    "M4":  { "blocks": [] }, "M5":  { "blocks": [] }, "M6":  { "blocks": [] },
