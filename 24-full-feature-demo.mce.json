  "events": {
    "GoHome":      { "name": "GoHome",      "payload": "{}" },
    "GoTasks":     { "name": "GoTasks",     "payload": "{}" },
    "GoProfile":   { "name": "GoProfile",   "payload": "{}" },
    "LoadTasks":   { "name": "LoadTasks",   "payload": "{}" },
    "ShowAddForm": { "name": "ShowAddForm", "payload": "{}" },
    "HideAddForm": { "name": "HideAddForm", "payload": "{}" },
    "SubmitTask":  { "name": "SubmitTask",  "payload": "{value}" },
    "RefreshConfig": { "name": "RefreshConfig", "payload": "{}" }
  },

  "pipes": {
    "fetchTasks": {
      "name": "fetchTasks",
      "method": "GET",
      "endpoint": "/api/tasks",
      "collection": "tasks",
      "direction": "out",
      "delay": 200
    },
    "addTask": {
      "name": "addTask",
      "method": "POST",
      "endpoint": "/api/tasks",
      "collection": "tasks",
      "direction": "in",
      "delay": 150
    },
    "fetchConfig": {
      "name": "fetchConfig",
      "method": "GET",
      "endpoint": "/api/config",
      "collection": "config",
      "direction": "out",
      "delay": 100
    }
  },

  "views": {
    "home":    { "name": "home"    },
    "tasks":   { "name": "tasks"   },
    "profile": { "name": "profile" }
  },

  "loops": {
    "taskLoop": {
      "name": "taskLoop",
      "pipeName": "fetchTasks",
      "targetId": "M41",
      "template": "<div style=\"display:flex;align-items:center;gap:16px;padding:14px 16px;border-bottom:1px solid #0d0d0d\"><span style=\"font-size:10px;color:#2a2a2a;min-width:20px;font-family:monospace\">{{_index}}</span><span style=\"font-size:14px;flex:1;color:#fff\">{{title}}{{value}}</span><span style=\"font-size:10px;letter-spacing:2px;color:#444\">{{status|UPPER}}</span><span style=\"font-size:10px;color:#2a2a2a;letter-spacing:1px;min-width:48px;text-align:right\">{{priority}}</span></div>",
      "description": "Renders each task doc from fetchTasks GET pipe into M41. Uses {{title}}{{value}} (seeded tasks use title; user-added tasks use value), {{status|UPPER}} applies UPPER filter inline, {{_index}} shows row number."
    }
  },

