    "M14": {
      "id": "M14", "tag": "p", "name": "confirm_text",
      "attrs": {}, "text": "✦  Entry signed! Your message was written to the guestbook collection via the guestPost pipe. Open the DB panel to see your entry.",
      "children": [], "parentId": "M13", "wires": [], "pipeBindings": [], "viewBinding": null,
      "css": { "font-size": "15px", "margin-bottom": "16px", "line-height": "1.7", "color": "#fff" }
