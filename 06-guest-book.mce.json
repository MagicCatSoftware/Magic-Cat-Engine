      "children": [], "parentId": "M4", "wires": [], "pipeBindings": [], "viewBinding": null,
      "css": { "background": "#fff", "color": "#000", "border": "none", "padding": "12px 28px", "font-size": "14px", "cursor": "pointer", "border-radius": "3px", "font-weight": "bold", "letter-spacing": "1px", "margin-right": "12px" }
    },
    "M12": {
      "id": "M12", "tag": "button", "name": "load_btn",
      "attrs": {
        "onclick": "PipeSystem.fetch('readGuests')"
      },
      "text": "Load Entries → Log",
      "children": [], "parentId": "M4", "wires": [], "pipeBindings": [], "viewBinding": null,
      "css": { "background": "transparent", "color": "#888", "border": "1px solid #444", "padding": "12px 24px", "font-size": "14px", "cursor": "pointer", "border-radius": "3px" }
