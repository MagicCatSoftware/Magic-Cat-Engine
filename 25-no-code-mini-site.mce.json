  "events": {
    "GoWelcome": { "name": "GoWelcome", "payload": "{}" },
    "GoCatalog": { "name": "GoCatalog", "payload": "{}" },
    "GoContact": { "name": "GoContact", "payload": "{}" },
    "LoadItems": { "name": "LoadItems", "payload": "{}" },
    "SubmitNote": { "name": "SubmitNote", "payload": "{value}" }
  },
  "pipes": {
    "fetchItems": {
      "name": "fetchItems",
      "method": "GET",
      "endpoint": "/api/items",
      "collection": "items",
      "direction": "out",
      "delay": 150,
      "schema": []
    },
    "addNote": {
      "name": "addNote",
      "method": "POST",
      "endpoint": "/api/notes",
      "collection": "notes",
      "direction": "in",
      "delay": 150,
      "schema": [
        { "key": "value", "type": "text" }
      ]
    }
  },
  "views": {
    "welcome": { "name": "welcome", "description": "Landing view" },
    "catalog": { "name": "catalog", "description": "Seeded DB catalog" },
    "contact": { "name": "contact", "description": "No-code note capture" }
  },
  "loops": {
    "itemLoop": {
      "name": "itemLoop",
      "pipeName": "fetchItems",
      "targetId": "M16",
      "template": "<div style=\"display:flex;align-items:center;gap:16px;padding:16px 18px;border-bottom:1px solid #202020\"><span style=\"font-size:11px;color:#737373;width:28px;font-family:monospace\">{{_index}}</span><span style=\"flex:1;color:#f5f5f5;font-size:15px\">{{name}}</span><span style=\"font-size:12px;color:#a3a3a3\">{{category|UPPER}}</span><span style=\"font-size:12px;color:#f5f5f5;font-weight:700;min-width:70px;text-align:right\">{{price|CURRENCY}}</span></div>",
      "description": "Renders item seed data from the fetchItems GET pipe. Uses built-in filters only."
    }
  },
