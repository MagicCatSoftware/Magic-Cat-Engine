        { "key": "name", "type": "text" },
        { "key": "text", "type": "text" },
        { "key": "css",  "type": "text" }
      ],
      "description": "Add a new machine definition to the build stack"
    },
    "getMachines": {
      "name": "getMachines",
      "method": "GET",
      "collection": "machines",
      "schema": [],
      "description": "Fetch all machine definitions in the stack"
    },
    "clearMachines": {
      "name": "clearMachines",
      "method": "DELETE",
      "collection": "machines",
      "schema": [],
      "description": "Clear the entire machine stack"
    }
  },
