  "pipes": {
    "loadFeed": {
      "name":"loadFeed","method":"GET","endpoint":"/api/feed","collection":"feed",
      "delay":200,"schema":[],"description":"Fetch all community feed posts"
    },
    "postUpdate": {
      "name":"postUpdate","method":"POST","endpoint":"/api/feed","collection":"feed",
      "delay":300,
      "schema":[
        {"key":"author","type":"text"},{"key":"tag","type":"text"},
        {"key":"message","type":"text"},{"key":"time","type":"text"}
      ],
      "description":"Post a community update to the feed"
    },
    "loadJobs": {
      "name":"loadJobs","method":"GET","endpoint":"/api/jobs","collection":"jobs",
      "delay":200,"schema":[],"description":"Fetch all open job listings"
    },
    "postJob": {
      "name":"postJob","method":"POST","endpoint":"/api/jobs","collection":"jobs",
      "delay":300,
      "schema":[
        {"key":"title","type":"text"},{"key":"company","type":"text"},
        {"key":"type","type":"text"},{"key":"location","type":"text"},
        {"key":"description","type":"text"},{"key":"posted","type":"text"}
      ],
      "description":"Post a new job listing"
    },
    "loadMembers": {
      "name":"loadMembers","method":"GET","endpoint":"/api/members","collection":"members",
      "delay":200,"schema":[],"description":"Fetch all community members"
    },
    "saveSettings": {
      "name":"saveSettings","method":"PUT","endpoint":"/api/settings","collection":"settings",
      "delay":300,
      "schema":[
        {"key":"app_name","type":"text"},{"key":"theme","type":"text"},
        {"key":"language","type":"text"},{"key":"notifications","type":"text"}
      ],
      "description":"Save app settings"
    }
  },

