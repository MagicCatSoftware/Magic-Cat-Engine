  "loops": {
    "feedList": {
      "name":"feedList","pipeName":"loadFeed","targetId":"M29",
      "description":"Renders community posts in the feed",
      "template":"<div style=\"background:#0d0d1a;border:1px solid #1e1e3a;border-radius:10px;padding:20px 24px;margin-bottom:12px;transition:border-color .2s\" onmouseover=\"this.style.borderColor='#7c6aff'\" onmouseout=\"this.style.borderColor='#1e1e3a'\"><div style=\"display:flex;align-items:center;gap:10px;margin-bottom:12px\"><div style=\"width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#7c6aff,#ff6b9d);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;color:#fff;flex-shrink:0\">{{author | INITIALS}}</div><span style=\"font-weight:700;font-size:14px;color:#e0e0f0\">{{author}}</span><span style=\"font-size:11px;color:#7c6aff;background:rgba(124,106,255,0.15);padding:2px 10px;border-radius:50px;font-weight:600\">{{tag}}</span><span style=\"margin-left:auto;font-size:11px;color:#3a3a5a\">{{time}}</span></div><p style=\"font-size:14px;color:#a0a0c0;line-height:1.65;margin:0\">{{message}}</p></div>"
    },
    "jobList": {
      "name":"jobList","pipeName":"loadJobs","targetId":"M48",
      "description":"Renders job listings",
      "template":"<div style=\"background:#0d0d1a;border:1px solid #1e1e3a;border-radius:10px;padding:20px 24px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:flex-start;transition:border-color .2s\" onmouseover=\"this.style.borderColor='#7c6aff'\" onmouseout=\"this.style.borderColor='#1e1e3a'\"><div><h3 style=\"font-size:15px;font-weight:700;color:#e0e0f0;margin:0 0 4px\">{{title}}</h3><div style=\"font-size:13px;color:#6060a0;margin-bottom:8px\">{{company}} · {{location}}</div><span style=\"font-size:11px;color:#7c6aff;background:rgba(124,106,255,0.15);padding:2px 10px;border-radius:50px;font-weight:600\">{{type}}</span></div><span style=\"font-size:11px;color:#3a3a5a;white-space:nowrap;margin-top:2px\">{{posted}}</span></div>"
    },
    "memberList": {
      "name":"memberList","pipeName":"loadMembers","targetId":"M58",
      "description":"Renders member cards in a grid",
      "template":"<div style=\"background:#0d0d1a;border:1px solid #1e1e3a;border-radius:10px;padding:24px 20px;text-align:center;transition:border-color .2s\" onmouseover=\"this.style.borderColor='#7c6aff'\" onmouseout=\"this.style.borderColor='#1e1e3a'\"><div style=\"width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,#7c6aff,#ff6b9d);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;color:#fff;margin:0 auto 12px\">{{name | INITIALS}}</div><div style=\"font-size:14px;font-weight:700;color:#e0e0f0;margin-bottom:3px\">{{name}}</div><div style=\"font-size:12px;color:#6060a0;margin-bottom:4px\">{{role | TITLE}}</div><div style=\"font-size:11px;color:#3a3a5a\">{{company}}</div></div>"
    }
  },

